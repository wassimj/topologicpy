@base <http://w3id.org/topologicpy#> .

@prefix top:     <http://w3id.org/topologicpy#> .
@prefix bot:     <https://w3id.org/bot#> .
@prefix brick:   <https://brickschema.org/schema/Brick#> .
@prefix ifc:     <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix schema:  <https://schema.org/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

<http://w3id.org/topologicpy#>
    rdf:type owl:Ontology ;
    dcterms:title "TopologicPy Ontology"@en ;
    dcterms:description "A formal OWL/RDFS vocabulary for representing TopologicPy topologies, graphs, dictionaries, geometric attributes, analytical metrics, provenance, and building-domain alignments."@en ;
    dcterms:creator "TopologicPy Project"@en ;
    dcterms:contributor "Wassim Jabi"@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:issued "2026-05-24"^^xsd:date ;
    dcterms:modified "2026-06-25"^^xsd:date ;
    owl:versionInfo "0.2.0" ;
    vann:preferredNamespacePrefix "top" ;
    vann:preferredNamespaceUri "http://w3id.org/topologicpy#" ;
    rdfs:label "TopologicPy Ontology"@en ;
    rdfs:comment "The canonical namespace prefix is top:. The vocabulary intentionally does not define or use a tpy: prefix or an inst: instance namespace. Instance namespaces should be supplied by applications."@en .

# -----------------------------------------------------------------------------
# Helper classes for union domains/ranges
# -----------------------------------------------------------------------------

top:TopologyOrGraph
    rdf:type owl:Class ;
    rdfs:label "Topology or Graph"@en ;
    rdfs:comment "Helper union class for properties that may be used by both topological entities and graph entities."@en ;
    owl:unionOf ( top:Topology top:Graph ) .

top:AnyEntity
    rdf:type owl:Class ;
    rdfs:label "Any TopologicPy Entity"@en ;
    rdfs:comment "Helper class for entities that may be topologies, graphs, dictionaries, attributes, analytical results, or provenance entities."@en .

# -----------------------------------------------------------------------------
# Core TopologicPy classes
# -----------------------------------------------------------------------------

top:Topology rdf:type owl:Class ; rdfs:label "Topology"@en ; rdfs:comment "The superclass for TopologicPy topological entities."@en .
top:Vertex rdf:type owl:Class ; rdfs:label "Vertex"@en ; rdfs:comment "A zero-dimensional topology representing a point in 3D space."@en ; rdfs:subClassOf top:Topology .
top:Point rdf:type owl:Class ; rdfs:label "Point"@en ; rdfs:comment "A point-like entity represented by or aligned with a vertex."@en ; rdfs:subClassOf top:Vertex .
top:Edge rdf:type owl:Class ; rdfs:label "Edge"@en ; rdfs:comment "A one-dimensional topology connecting two vertices."@en ; rdfs:subClassOf top:Topology .
top:Wire rdf:type owl:Class ; rdfs:label "Wire"@en ; rdfs:comment "A connected sequence or collection of edges."@en ; rdfs:subClassOf top:Topology .
top:Face rdf:type owl:Class ; rdfs:label "Face"@en ; rdfs:comment "A bounded two-dimensional surface, optionally with internal boundaries."@en ; rdfs:subClassOf top:Topology, geo:Feature .
top:Shell rdf:type owl:Class ; rdfs:label "Shell"@en ; rdfs:comment "A connected collection of faces forming a segmented surface."@en ; rdfs:subClassOf top:Topology .
top:Cell rdf:type owl:Class ; rdfs:label "Cell"@en ; rdfs:comment "A volumetric topological entity bounded by faces."@en ; rdfs:subClassOf top:Topology, geo:Feature .
top:CellComplex rdf:type owl:Class ; rdfs:label "Cell Complex"@en ; rdfs:comment "A collection of cells, typically sharing faces."@en ; rdfs:subClassOf top:Topology .
top:Cluster rdf:type owl:Class ; rdfs:label "Cluster"@en ; rdfs:comment "A heterogeneous collection of topologies."@en ; rdfs:subClassOf top:Topology .
top:Aperture rdf:type owl:Class ; rdfs:label "Aperture"@en ; rdfs:comment "An opening, void, or aperture associated with another topology."@en ; rdfs:subClassOf top:Face, top:Element, bot:Element .

top:Dictionary rdf:type owl:Class ; rdfs:label "Dictionary"@en ; rdfs:comment "A key-value container for semantic, analytical, and provenance metadata."@en .
top:Attribute rdf:type owl:Class ; rdfs:label "Attribute"@en ; rdfs:comment "A semantic or analytical key-value attribute associated with an entity."@en .
top:Vector rdf:type owl:Class ; rdfs:label "Vector"@en ; rdfs:comment "A mathematical vector with magnitude and direction."@en .
top:Matrix rdf:type owl:Class ; rdfs:label "Matrix"@en ; rdfs:comment "A matrix, typically used for geometric transformations."@en .
top:CoordinateSystem rdf:type owl:Class ; rdfs:label "Coordinate System"@en ; rdfs:comment "A spatial reference frame for coordinates and transformations."@en .
top:Transform rdf:type owl:Class ; rdfs:label "Transform"@en ; rdfs:comment "A geometric or topological transformation."@en .
top:Grid rdf:type owl:Class ; rdfs:label "Grid"@en ; rdfs:comment "A regular spatial subdivision or sampling structure."@en .
top:Context rdf:type owl:Class ; rdfs:label "Context"@en ; rdfs:comment "The modelling, analytical, or computational context in which entities are interpreted."@en .
top:Project rdf:type owl:Class ; rdfs:label "Project"@en ; rdfs:comment "A project-level container for a model, dataset, or computational study."@en ; rdfs:subClassOf prov:Entity .

# -----------------------------------------------------------------------------
# Building and spatial-domain classes
# -----------------------------------------------------------------------------

top:Zone rdf:type owl:Class ; rdfs:label "Zone"@en ; rdfs:comment "A spatial region or bounded domain."@en ; rdfs:subClassOf top:Cell, bot:Zone .
top:Site rdf:type owl:Class ; rdfs:label "Site"@en ; rdfs:comment "A site or land parcel containing buildings or spatial zones."@en ; rdfs:subClassOf top:Zone, bot:Site .
top:Building rdf:type owl:Class ; rdfs:label "Building"@en ; rdfs:comment "A building-level spatial container."@en ; rdfs:subClassOf top:Zone, bot:Building .
top:Storey rdf:type owl:Class ; rdfs:label "Storey"@en ; rdfs:comment "A building storey or level."@en ; rdfs:subClassOf top:Zone, bot:Storey .
top:Space rdf:type owl:Class ; rdfs:label "Space"@en ; rdfs:comment "A building space, usually corresponding to an IFC space or room-like domain."@en ; rdfs:subClassOf top:Zone, bot:Space .
top:Room rdf:type owl:Class ; rdfs:label "Room"@en ; rdfs:comment "A room or occupiable space."@en ; rdfs:subClassOf top:Space .
top:ThermalZone rdf:type owl:Class ; rdfs:label "Thermal Zone"@en ; rdfs:comment "A thermal analysis zone."@en ; rdfs:subClassOf top:Space .
top:FunctionalZone rdf:type owl:Class ; rdfs:label "Functional Zone"@en ; rdfs:comment "A zone grouped by function or programme."@en ; rdfs:subClassOf top:Zone .
top:CirculationZone rdf:type owl:Class ; rdfs:label "Circulation Zone"@en ; rdfs:comment "A zone primarily used for movement or circulation."@en ; rdfs:subClassOf top:Zone .

top:Element rdf:type owl:Class ; rdfs:label "Element"@en ; rdfs:comment "A physical or conceptual building element."@en ; rdfs:subClassOf top:Topology, bot:Element .
top:Wall rdf:type owl:Class ; rdfs:label "Wall"@en ; rdfs:comment "A vertical or near-vertical building element separating or bounding spaces."@en ; rdfs:subClassOf top:Element .
top:Door rdf:type owl:Class ; rdfs:label "Door"@en ; rdfs:comment "A door or access element."@en ; rdfs:subClassOf top:Element .
top:Window rdf:type owl:Class ; rdfs:label "Window"@en ; rdfs:comment "A window or transparent/translucent opening element."@en ; rdfs:subClassOf top:Element .
top:Slab rdf:type owl:Class ; rdfs:label "Slab"@en ; rdfs:comment "A slab, floor, ceiling, or plate-like element."@en ; rdfs:subClassOf top:Element .
top:Roof rdf:type owl:Class ; rdfs:label "Roof"@en ; rdfs:comment "A roof element."@en ; rdfs:subClassOf top:Element .
top:Column rdf:type owl:Class ; rdfs:label "Column"@en ; rdfs:comment "A column or vertical structural member."@en ; rdfs:subClassOf top:Element .
top:Beam rdf:type owl:Class ; rdfs:label "Beam"@en ; rdfs:comment "A beam or horizontal/linear structural member."@en ; rdfs:subClassOf top:Element .
top:Stair rdf:type owl:Class ; rdfs:label "Stair"@en ; rdfs:comment "A stair or stair flight."@en ; rdfs:subClassOf top:Element .
top:Railing rdf:type owl:Class ; rdfs:label "Railing"@en ; rdfs:comment "A railing, guard, or balustrade."@en ; rdfs:subClassOf top:Element .
top:Opening rdf:type owl:Class ; rdfs:label "Opening"@en ; rdfs:comment "An opening element or void."@en ; rdfs:subClassOf top:Element .
top:Furniture rdf:type owl:Class ; rdfs:label "Furniture"@en ; rdfs:comment "Furniture or furnishing elements."@en ; rdfs:subClassOf top:Element .
top:Equipment rdf:type owl:Class ; rdfs:label "Equipment"@en ; rdfs:comment "Building equipment or operational systems."@en ; rdfs:subClassOf top:Element, brick:Equipment .
top:Sensor rdf:type owl:Class ; rdfs:label "Sensor"@en ; rdfs:comment "A sensor or observation point."@en ; rdfs:subClassOf top:Element, brick:Point .

top:Surface rdf:type owl:Class ; rdfs:label "Surface"@en ; rdfs:comment "A surface used as a geometric, analytical, or building-domain entity."@en ; rdfs:subClassOf top:Face .
top:Boundary rdf:type owl:Class ; rdfs:label "Boundary"@en ; rdfs:comment "A topology that bounds another topology."@en ; rdfs:subClassOf top:Topology .
top:ExternalBoundary rdf:type owl:Class ; rdfs:label "External Boundary"@en ; rdfs:comment "An external boundary of a topology."@en ; rdfs:subClassOf top:Boundary .
top:InternalBoundary rdf:type owl:Class ; rdfs:label "Internal Boundary"@en ; rdfs:comment "An internal boundary, hole, or void boundary."@en ; rdfs:subClassOf top:Boundary .
top:Interface rdf:type owl:Class ; rdfs:label "Interface"@en ; rdfs:comment "A shared boundary or interface between zones, elements, or topologies."@en ; rdfs:subClassOf top:Face, bot:Interface .

# -----------------------------------------------------------------------------
# Graph classes
# -----------------------------------------------------------------------------

top:Graph rdf:type owl:Class ; rdfs:label "Graph"@en ; rdfs:comment "A graph composed of nodes and relationships, commonly represented in TopologicPy by vertices and edges."@en .
top:Node rdf:type owl:Class ; rdfs:label "Node"@en ; rdfs:comment "A graph node, often represented by a TopologicPy Vertex."@en ; rdfs:subClassOf top:Vertex .
top:Relationship rdf:type owl:Class ; rdfs:label "Relationship"@en ; rdfs:comment "A graph relationship, often represented by a TopologicPy Edge."@en ; rdfs:subClassOf top:Edge .
top:DirectedRelationship rdf:type owl:Class ; rdfs:label "Directed Relationship"@en ; rdfs:comment "A relationship with a start node and an end node."@en ; rdfs:subClassOf top:Relationship .
top:UndirectedRelationship rdf:type owl:Class ; rdfs:label "Undirected Relationship"@en ; rdfs:comment "A relationship without intrinsic direction."@en ; rdfs:subClassOf top:Relationship .
top:SpatialGraph rdf:type owl:Class ; rdfs:label "Spatial Graph"@en ; rdfs:comment "A graph representing spatial relations."@en ; rdfs:subClassOf top:Graph .
top:AdjacencyGraph rdf:type owl:Class ; rdfs:label "Adjacency Graph"@en ; rdfs:comment "A graph representing adjacency relations."@en ; rdfs:subClassOf top:SpatialGraph .
top:VisibilityGraph rdf:type owl:Class ; rdfs:label "Visibility Graph"@en ; rdfs:comment "A graph representing visibility relations."@en ; rdfs:subClassOf top:SpatialGraph .
top:CirculationGraph rdf:type owl:Class ; rdfs:label "Circulation Graph"@en ; rdfs:comment "A graph representing movement or circulation relations."@en ; rdfs:subClassOf top:SpatialGraph .
top:ConnectivityGraph rdf:type owl:Class ; rdfs:label "Connectivity Graph"@en ; rdfs:comment "A graph representing connectivity relations."@en ; rdfs:subClassOf top:SpatialGraph .
top:KnowledgeGraph rdf:type owl:Class ; rdfs:label "Knowledge Graph"@en ; rdfs:comment "A graph integrating entities, semantics, provenance, and relationships."@en ; rdfs:subClassOf top:Graph .
top:Path rdf:type owl:Class ; rdfs:label "Path"@en ; rdfs:comment "An ordered sequence of graph nodes and relationships."@en ; rdfs:subClassOf top:Graph .

top:GraphDataset rdf:type owl:Class ; rdfs:label "Graph Dataset"@en ; rdfs:comment "A dataset containing graphs, nodes, edges, labels, and features."@en ; rdfs:subClassOf prov:Entity .
top:GraphFeature rdf:type owl:Class ; rdfs:label "Graph Feature"@en ; rdfs:comment "A numerical or categorical feature associated with a graph."@en ; rdfs:subClassOf top:Attribute .
top:NodeFeature rdf:type owl:Class ; rdfs:label "Node Feature"@en ; rdfs:comment "A numerical or categorical feature associated with a graph node."@en ; rdfs:subClassOf top:Attribute .
top:EdgeFeature rdf:type owl:Class ; rdfs:label "Edge Feature"@en ; rdfs:comment "A numerical or categorical feature associated with a graph edge."@en ; rdfs:subClassOf top:Attribute .

top:AnalysisMetric rdf:type owl:Class ; rdfs:label "Analysis Metric"@en ; rdfs:comment "A computed metric associated with geometry, topology, graphs, or buildings."@en .
top:SpaceSyntaxMetric rdf:type owl:Class ; rdfs:label "Space Syntax Metric"@en ; rdfs:comment "A spatial network metric commonly used in space syntax analysis."@en ; rdfs:subClassOf top:AnalysisMetric .
top:Isovist rdf:type owl:Class ; rdfs:label "Isovist"@en ; rdfs:comment "A visibility polygon, volume, or related visibility field from an observer point."@en ; rdfs:subClassOf top:AnalysisMetric .
top:QualityIssue rdf:type owl:Class ; rdfs:label "Quality Issue"@en ; rdfs:comment "A validation, quality-control, or model-checking issue."@en .
top:ValidationRule rdf:type owl:Class ; rdfs:label "Validation Rule"@en ; rdfs:comment "A rule used to validate model content, geometry, topology, semantics, or provenance."@en .

# IFC / BOT alignments

top:Project skos:closeMatch ifc:IfcProject .
top:Site skos:closeMatch ifc:IfcSite .
top:Building skos:closeMatch ifc:IfcBuilding .
top:Storey skos:closeMatch ifc:IfcBuildingStorey .
top:Space skos:closeMatch ifc:IfcSpace .
top:Zone skos:closeMatch ifc:IfcZone .
top:Wall skos:closeMatch ifc:IfcWall .
top:Door skos:closeMatch ifc:IfcDoor .
top:Window skos:closeMatch ifc:IfcWindow .
top:Slab skos:closeMatch ifc:IfcSlab .
top:Roof skos:closeMatch ifc:IfcRoof .
top:Column skos:closeMatch ifc:IfcColumn .
top:Beam skos:closeMatch ifc:IfcBeam .
top:Stair skos:closeMatch ifc:IfcStair .
top:Railing skos:closeMatch ifc:IfcRailing .
top:Opening skos:closeMatch ifc:IfcOpeningElement .
top:Furniture skos:closeMatch ifc:IfcFurnishingElement .
top:Equipment skos:closeMatch ifc:IfcDistributionElement .
top:Interface skos:closeMatch ifc:IfcRelSpaceBoundary .

# -----------------------------------------------------------------------------
# Object properties: topology containment and decomposition
# -----------------------------------------------------------------------------

top:hasTopology rdf:type owl:ObjectProperty ; rdfs:label "has topology"@en ; rdfs:comment "Associates an entity with a topology."@en ; rdfs:range top:Topology ; owl:inverseOf top:isTopologyOf .
top:isTopologyOf rdf:type owl:ObjectProperty ; rdfs:label "is topology of"@en ; rdfs:comment "Inverse of hasTopology."@en ; rdfs:domain top:Topology ; owl:inverseOf top:hasTopology .

top:hasSubTopology rdf:type owl:ObjectProperty ; rdfs:label "has subtopology"@en ; rdfs:comment "Associates a topology or graph with a subtopology."@en ; rdfs:domain top:TopologyOrGraph ; rdfs:range top:Topology ; owl:inverseOf top:isSubTopologyOf .
top:isSubTopologyOf rdf:type owl:ObjectProperty ; rdfs:label "is subtopology of"@en ; rdfs:comment "Associates a topology with a parent topology or graph."@en ; rdfs:domain top:Topology ; rdfs:range top:TopologyOrGraph ; owl:inverseOf top:hasSubTopology .

top:hasFreeTopology rdf:type owl:ObjectProperty ; rdfs:label "has free topology"@en ; rdfs:comment "Associates a cluster with a free or heterogeneous contained topology."@en ; rdfs:domain top:Cluster ; rdfs:range top:Topology ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isFreeTopologyOf .
top:isFreeTopologyOf rdf:type owl:ObjectProperty ; rdfs:label "is free topology of"@en ; rdfs:comment "Associates a topology with a containing cluster."@en ; rdfs:domain top:Topology ; rdfs:range top:Cluster ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasFreeTopology .

top:hasVertex rdf:type owl:ObjectProperty ; rdfs:label "has vertex"@en ; rdfs:comment "Associates a topology or graph with a vertex."@en ; rdfs:domain top:TopologyOrGraph ; rdfs:range top:Vertex ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isVertexOf .
top:isVertexOf rdf:type owl:ObjectProperty ; rdfs:label "is vertex of"@en ; rdfs:comment "Associates a vertex with its parent topology or graph."@en ; rdfs:domain top:Vertex ; rdfs:range top:TopologyOrGraph ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasVertex .
top:hasEdge rdf:type owl:ObjectProperty ; rdfs:label "has edge"@en ; rdfs:comment "Associates a topology or graph with an edge."@en ; rdfs:domain top:TopologyOrGraph ; rdfs:range top:Edge ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isEdgeOf .
top:isEdgeOf rdf:type owl:ObjectProperty ; rdfs:label "is edge of"@en ; rdfs:comment "Associates an edge with its parent topology or graph."@en ; rdfs:domain top:Edge ; rdfs:range top:TopologyOrGraph ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasEdge .
top:hasWire rdf:type owl:ObjectProperty ; rdfs:label "has wire"@en ; rdfs:comment "Associates a topology with a wire."@en ; rdfs:domain top:Topology ; rdfs:range top:Wire ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isWireOf .
top:isWireOf rdf:type owl:ObjectProperty ; rdfs:label "is wire of"@en ; rdfs:comment "Associates a wire with its parent topology."@en ; rdfs:domain top:Wire ; rdfs:range top:Topology ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasWire .
top:hasFace rdf:type owl:ObjectProperty ; rdfs:label "has face"@en ; rdfs:comment "Associates a topology with a face."@en ; rdfs:domain top:Topology ; rdfs:range top:Face ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isFaceOf .
top:isFaceOf rdf:type owl:ObjectProperty ; rdfs:label "is face of"@en ; rdfs:comment "Associates a face with its parent topology."@en ; rdfs:domain top:Face ; rdfs:range top:Topology ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasFace .
top:hasShell rdf:type owl:ObjectProperty ; rdfs:label "has shell"@en ; rdfs:comment "Associates a topology with a shell."@en ; rdfs:domain top:Topology ; rdfs:range top:Shell ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isShellOf .
top:isShellOf rdf:type owl:ObjectProperty ; rdfs:label "is shell of"@en ; rdfs:comment "Associates a shell with its parent topology."@en ; rdfs:domain top:Shell ; rdfs:range top:Topology ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasShell .
top:hasCell rdf:type owl:ObjectProperty ; rdfs:label "has cell"@en ; rdfs:comment "Associates a topology with a cell."@en ; rdfs:domain top:Topology ; rdfs:range top:Cell ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isCellOf .
top:isCellOf rdf:type owl:ObjectProperty ; rdfs:label "is cell of"@en ; rdfs:comment "Associates a cell with its parent topology."@en ; rdfs:domain top:Cell ; rdfs:range top:Topology ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasCell .
top:hasCellComplex rdf:type owl:ObjectProperty ; rdfs:label "has cell complex"@en ; rdfs:comment "Associates a topology or cluster with a cell complex."@en ; rdfs:domain top:TopologyOrGraph ; rdfs:range top:CellComplex ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isCellComplexOf .
top:isCellComplexOf rdf:type owl:ObjectProperty ; rdfs:label "is cell complex of"@en ; rdfs:comment "Associates a cell complex with its parent topology or cluster."@en ; rdfs:domain top:CellComplex ; rdfs:range top:TopologyOrGraph ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasCellComplex .
top:hasAperture rdf:type owl:ObjectProperty ; rdfs:label "has aperture"@en ; rdfs:comment "Associates a topology with an aperture."@en ; rdfs:domain top:Topology ; rdfs:range top:Aperture ; rdfs:subPropertyOf top:hasSubTopology ; owl:inverseOf top:isApertureOf .
top:isApertureOf rdf:type owl:ObjectProperty ; rdfs:label "is aperture of"@en ; rdfs:comment "Associates an aperture with the topology it belongs to."@en ; rdfs:domain top:Aperture ; rdfs:range top:Topology ; rdfs:subPropertyOf top:isSubTopologyOf ; owl:inverseOf top:hasAperture .

# Legacy plural aliases retained for compatibility with older exports.
top:hasVertices rdf:type owl:ObjectProperty ; rdfs:label "has vertices"@en ; rdfs:comment "Compatibility alias for top:hasVertex."@en ; rdfs:subPropertyOf top:hasVertex .
top:hasEdges rdf:type owl:ObjectProperty ; rdfs:label "has edges"@en ; rdfs:comment "Compatibility alias for top:hasEdge."@en ; rdfs:subPropertyOf top:hasEdge .
top:hasWires rdf:type owl:ObjectProperty ; rdfs:label "has wires"@en ; rdfs:comment "Compatibility alias for top:hasWire."@en ; rdfs:subPropertyOf top:hasWire .
top:hasFaces rdf:type owl:ObjectProperty ; rdfs:label "has faces"@en ; rdfs:comment "Compatibility alias for top:hasFace."@en ; rdfs:subPropertyOf top:hasFace .
top:hasShells rdf:type owl:ObjectProperty ; rdfs:label "has shells"@en ; rdfs:comment "Compatibility alias for top:hasShell."@en ; rdfs:subPropertyOf top:hasShell .
top:hasCells rdf:type owl:ObjectProperty ; rdfs:label "has cells"@en ; rdfs:comment "Compatibility alias for top:hasCell."@en ; rdfs:subPropertyOf top:hasCell .
top:hasCellComplexes rdf:type owl:ObjectProperty ; rdfs:label "has cell complexes"@en ; rdfs:comment "Compatibility alias for top:hasCellComplex."@en ; rdfs:subPropertyOf top:hasCellComplex .

# -----------------------------------------------------------------------------
# Object properties: boundaries, containment, and spatial relations
# -----------------------------------------------------------------------------

top:bounds rdf:type owl:ObjectProperty ; rdfs:label "bounds"@en ; rdfs:comment "Indicates that one topology bounds another."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology ; owl:inverseOf top:isBoundedBy .
top:isBoundedBy rdf:type owl:ObjectProperty ; rdfs:label "is bounded by"@en ; rdfs:comment "Indicates that one topology is bounded by another."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology ; owl:inverseOf top:bounds .
top:hasExternalBoundary rdf:type owl:ObjectProperty ; rdfs:label "has external boundary"@en ; rdfs:comment "Associates a topology with an external boundary."@en ; rdfs:domain top:Topology ; rdfs:range top:Boundary ; rdfs:subPropertyOf top:isBoundedBy ; owl:inverseOf top:isExternalBoundaryOf .
top:isExternalBoundaryOf rdf:type owl:ObjectProperty ; rdfs:label "is external boundary of"@en ; rdfs:comment "Associates an external boundary with the topology it bounds."@en ; rdfs:domain top:Boundary ; rdfs:range top:Topology ; rdfs:subPropertyOf top:bounds ; owl:inverseOf top:hasExternalBoundary .
top:hasInternalBoundary rdf:type owl:ObjectProperty ; rdfs:label "has internal boundary"@en ; rdfs:comment "Associates a topology with an internal boundary, hole, or void boundary."@en ; rdfs:domain top:Topology ; rdfs:range top:Boundary ; rdfs:subPropertyOf top:isBoundedBy ; owl:inverseOf top:isInternalBoundaryOf .
top:isInternalBoundaryOf rdf:type owl:ObjectProperty ; rdfs:label "is internal boundary of"@en ; rdfs:comment "Associates an internal boundary with the topology it bounds."@en ; rdfs:domain top:Boundary ; rdfs:range top:Topology ; rdfs:subPropertyOf top:bounds ; owl:inverseOf top:hasInternalBoundary .
top:hasInternalBoundaries rdf:type owl:ObjectProperty ; rdfs:label "has internal boundaries"@en ; rdfs:comment "Compatibility alias for top:hasInternalBoundary."@en ; rdfs:subPropertyOf top:hasInternalBoundary .

top:hasInterface rdf:type owl:ObjectProperty ; rdfs:label "has interface"@en ; rdfs:comment "Associates a topology with an interface."@en ; rdfs:domain top:Topology ; rdfs:range top:Interface ; owl:inverseOf top:isInterfaceOf .
top:isInterfaceOf rdf:type owl:ObjectProperty ; rdfs:label "is interface of"@en ; rdfs:comment "Associates an interface with the topology, zone, or element it interfaces."@en ; rdfs:domain top:Interface ; rdfs:range top:Topology ; owl:inverseOf top:hasInterface .
top:interfaceOf rdf:type owl:ObjectProperty ; rdfs:label "interface of"@en ; rdfs:comment "Compatibility alias for top:isInterfaceOf used by TopologicPy dictionary exports."@en ; rdfs:subPropertyOf top:isInterfaceOf .

top:contains rdf:type owl:ObjectProperty, owl:TransitiveProperty ; rdfs:label "contains"@en ; rdfs:comment "Indicates topological, geometric, or semantic containment."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology ; owl:inverseOf top:isContainedIn .
top:isContainedIn rdf:type owl:ObjectProperty, owl:TransitiveProperty ; rdfs:label "is contained in"@en ; rdfs:comment "Inverse of contains."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology ; owl:inverseOf top:contains .
top:containsElement rdf:type owl:ObjectProperty ; rdfs:label "contains element"@en ; rdfs:comment "Associates a topology or zone with a contained element."@en ; rdfs:domain top:Topology ; rdfs:range top:Element ; rdfs:subPropertyOf top:contains ; owl:inverseOf top:isElementOf .
top:isElementOf rdf:type owl:ObjectProperty ; rdfs:label "is element of"@en ; rdfs:comment "Associates an element with its container."@en ; rdfs:domain top:Element ; rdfs:range top:Topology ; rdfs:subPropertyOf top:isContainedIn ; owl:inverseOf top:containsElement .
top:containsZone rdf:type owl:ObjectProperty ; rdfs:label "contains zone"@en ; rdfs:comment "Associates a zone with a contained zone."@en ; rdfs:domain top:Zone ; rdfs:range top:Zone ; rdfs:subPropertyOf top:contains ; owl:inverseOf top:isZoneOf .
top:isZoneOf rdf:type owl:ObjectProperty ; rdfs:label "is zone of"@en ; rdfs:comment "Associates a zone with a containing zone."@en ; rdfs:domain top:Zone ; rdfs:range top:Zone ; rdfs:subPropertyOf top:isContainedIn ; owl:inverseOf top:containsZone .
top:isPartOf rdf:type owl:ObjectProperty, owl:TransitiveProperty ; rdfs:label "is part of"@en ; rdfs:comment "Associates an entity with a containing, parent, or aggregate entity."@en ; rdfs:subPropertyOf top:isContainedIn .

top:adjacentTo rdf:type owl:ObjectProperty, owl:SymmetricProperty ; rdfs:label "adjacent to"@en ; rdfs:comment "Indicates that two topologies are adjacent."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology .
top:connectsTo rdf:type owl:ObjectProperty ; rdfs:label "connects to"@en ; rdfs:comment "Indicates that one topology or graph node is connected to another."@en ; rdfs:domain top:TopologyOrGraph ; rdfs:range top:TopologyOrGraph .
top:connectedTo rdf:type owl:ObjectProperty ; rdfs:label "connected to"@en ; rdfs:comment "Compatibility alias for top:connectsTo."@en ; rdfs:subPropertyOf top:connectsTo .
top:intersects rdf:type owl:ObjectProperty, owl:SymmetricProperty ; rdfs:label "intersects"@en ; rdfs:comment "Indicates that two topologies intersect."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology .
top:overlaps rdf:type owl:ObjectProperty, owl:SymmetricProperty ; rdfs:label "overlaps"@en ; rdfs:comment "Indicates that two topologies overlap."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology .
top:touches rdf:type owl:ObjectProperty, owl:SymmetricProperty ; rdfs:label "touches"@en ; rdfs:comment "Indicates that two topologies touch."@en ; rdfs:domain top:Topology ; rdfs:range top:Topology .

# -----------------------------------------------------------------------------
# Object properties: graph-specific relations
# -----------------------------------------------------------------------------

top:hasNode rdf:type owl:ObjectProperty ; rdfs:label "has node"@en ; rdfs:comment "Associates a graph with one of its nodes."@en ; rdfs:domain top:Graph ; rdfs:range top:Node ; rdfs:subPropertyOf top:hasVertex ; owl:inverseOf top:isNodeOf .
top:isNodeOf rdf:type owl:ObjectProperty ; rdfs:label "is node of"@en ; rdfs:comment "Associates a node with the graph to which it belongs."@en ; rdfs:domain top:Node ; rdfs:range top:Graph ; rdfs:subPropertyOf top:isVertexOf ; owl:inverseOf top:hasNode .
top:hasRelationship rdf:type owl:ObjectProperty ; rdfs:label "has relationship"@en ; rdfs:comment "Associates a graph with one of its relationships."@en ; rdfs:domain top:Graph ; rdfs:range top:Relationship ; rdfs:subPropertyOf top:hasEdge ; owl:inverseOf top:isRelationshipOf .
top:isRelationshipOf rdf:type owl:ObjectProperty ; rdfs:label "is relationship of"@en ; rdfs:comment "Associates a relationship with the graph to which it belongs."@en ; rdfs:domain top:Relationship ; rdfs:range top:Graph ; rdfs:subPropertyOf top:isEdgeOf ; owl:inverseOf top:hasRelationship .
top:startsAt rdf:type owl:ObjectProperty ; rdfs:label "starts at"@en ; rdfs:comment "Associates an edge or relationship with its starting vertex or node."@en ; rdfs:domain top:Edge ; rdfs:range top:Vertex .
top:endsAt rdf:type owl:ObjectProperty ; rdfs:label "ends at"@en ; rdfs:comment "Associates an edge or relationship with its ending vertex or node."@en ; rdfs:domain top:Edge ; rdfs:range top:Vertex .
top:hasStartVertex rdf:type owl:ObjectProperty ; rdfs:label "has start vertex"@en ; rdfs:comment "Compatibility alias for top:startsAt."@en ; rdfs:subPropertyOf top:startsAt .
top:hasEndVertex rdf:type owl:ObjectProperty ; rdfs:label "has end vertex"@en ; rdfs:comment "Compatibility alias for top:endsAt."@en ; rdfs:subPropertyOf top:endsAt .

# -----------------------------------------------------------------------------
# Object properties: dictionaries, attributes, features, provenance
# -----------------------------------------------------------------------------

top:hasDictionary rdf:type owl:ObjectProperty ; rdfs:label "has dictionary"@en ; rdfs:comment "Associates an entity with a TopologicPy dictionary."@en ; rdfs:range top:Dictionary ; owl:inverseOf top:isDictionaryOf .
top:isDictionaryOf rdf:type owl:ObjectProperty ; rdfs:label "is dictionary of"@en ; rdfs:comment "Associates a dictionary with the entity it describes."@en ; rdfs:domain top:Dictionary ; owl:inverseOf top:hasDictionary .
top:hasAttribute rdf:type owl:ObjectProperty ; rdfs:label "has attribute"@en ; rdfs:comment "Associates an entity with an attribute."@en ; rdfs:range top:Attribute ; owl:inverseOf top:isAttributeOf .
top:isAttributeOf rdf:type owl:ObjectProperty ; rdfs:label "is attribute of"@en ; rdfs:comment "Associates an attribute with the entity it describes."@en ; rdfs:domain top:Attribute ; owl:inverseOf top:hasAttribute .
top:hasGraphFeature rdf:type owl:ObjectProperty ; rdfs:label "has graph feature"@en ; rdfs:comment "Associates a graph with a graph-level feature."@en ; rdfs:domain top:Graph ; rdfs:range top:GraphFeature ; rdfs:subPropertyOf top:hasAttribute .
top:hasNodeFeature rdf:type owl:ObjectProperty ; rdfs:label "has node feature"@en ; rdfs:comment "Associates a node with a node-level feature."@en ; rdfs:domain top:Node ; rdfs:range top:NodeFeature ; rdfs:subPropertyOf top:hasAttribute .
top:hasEdgeFeature rdf:type owl:ObjectProperty ; rdfs:label "has edge feature"@en ; rdfs:comment "Associates a relationship or edge with an edge-level feature."@en ; rdfs:domain top:Relationship ; rdfs:range top:EdgeFeature ; rdfs:subPropertyOf top:hasAttribute .
top:hasMetric rdf:type owl:ObjectProperty ; rdfs:label "has metric"@en ; rdfs:comment "Associates an entity with an analytical metric."@en ; rdfs:range top:AnalysisMetric ; rdfs:subPropertyOf top:hasAttribute .
top:hasDirection rdf:type owl:ObjectProperty ; rdfs:label "has direction"@en ; rdfs:comment "Associates an entity with a direction vector."@en ; rdfs:range top:Vector .
top:hasCoordinateSystem rdf:type owl:ObjectProperty ; rdfs:label "has coordinate system"@en ; rdfs:comment "Associates an entity with a coordinate system."@en ; rdfs:range top:CoordinateSystem .
top:hasTransform rdf:type owl:ObjectProperty ; rdfs:label "has transform"@en ; rdfs:comment "Associates an entity with a transformation."@en ; rdfs:range top:Transform .
top:generatedBy rdf:type owl:ObjectProperty ; rdfs:label "generated by"@en ; rdfs:comment "Associates an entity with the process or agent that generated it."@en ; rdfs:subPropertyOf prov:wasGeneratedBy .
top:derivedFrom rdf:type owl:ObjectProperty ; rdfs:label "derived from"@en ; rdfs:comment "Associates an entity with a source entity from which it was derived."@en ; rdfs:subPropertyOf prov:wasDerivedFrom .

# -----------------------------------------------------------------------------
# Data properties: geometry and measurement
# -----------------------------------------------------------------------------

top:x rdf:type owl:DatatypeProperty ; rdfs:label "x"@en ; rdfs:comment "The X coordinate of a vertex or point-like entity."@en ; rdfs:domain top:Vertex ; rdfs:range xsd:double .
top:y rdf:type owl:DatatypeProperty ; rdfs:label "y"@en ; rdfs:comment "The Y coordinate of a vertex or point-like entity."@en ; rdfs:domain top:Vertex ; rdfs:range xsd:double .
top:z rdf:type owl:DatatypeProperty ; rdfs:label "z"@en ; rdfs:comment "The Z coordinate of a vertex or point-like entity."@en ; rdfs:domain top:Vertex ; rdfs:range xsd:double .
top:hasX rdf:type owl:DatatypeProperty ; rdfs:label "has X"@en ; rdfs:comment "Compatibility alias for top:x."@en ; rdfs:subPropertyOf top:x .
top:hasY rdf:type owl:DatatypeProperty ; rdfs:label "has Y"@en ; rdfs:comment "Compatibility alias for top:y."@en ; rdfs:subPropertyOf top:y .
top:hasZ rdf:type owl:DatatypeProperty ; rdfs:label "has Z"@en ; rdfs:comment "Compatibility alias for top:z."@en ; rdfs:subPropertyOf top:z .

top:length rdf:type owl:DatatypeProperty ; rdfs:label "length"@en ; rdfs:comment "The length of an edge, wire, path, or other measurable entity."@en ; rdfs:range xsd:double .
top:area rdf:type owl:DatatypeProperty ; rdfs:label "area"@en ; rdfs:comment "The area of a face, shell, cell, or cell complex."@en ; rdfs:range xsd:double .
top:volume rdf:type owl:DatatypeProperty ; rdfs:label "volume"@en ; rdfs:comment "The volume of a cell or cell complex."@en ; rdfs:range xsd:double .
top:mantissa rdf:type owl:DatatypeProperty ; rdfs:label "mantissa"@en ; rdfs:comment "The number of decimal places used to report values."@en ; rdfs:range xsd:integer .
top:unit rdf:type owl:DatatypeProperty ; rdfs:label "unit"@en ; rdfs:comment "The unit of measurement."@en ; rdfs:range xsd:string .
top:hasLength rdf:type owl:DatatypeProperty ; rdfs:label "has length"@en ; rdfs:comment "Compatibility alias for top:length."@en ; rdfs:subPropertyOf top:length .
top:hasArea rdf:type owl:DatatypeProperty ; rdfs:label "has area"@en ; rdfs:comment "Compatibility alias for top:area."@en ; rdfs:subPropertyOf top:area .
top:hasVolume rdf:type owl:DatatypeProperty ; rdfs:label "has volume"@en ; rdfs:comment "Compatibility alias for top:volume."@en ; rdfs:subPropertyOf top:volume .
top:hasMantissa rdf:type owl:DatatypeProperty ; rdfs:label "has mantissa"@en ; rdfs:comment "Compatibility alias for top:mantissa."@en ; rdfs:subPropertyOf top:mantissa .
top:hasUnit rdf:type owl:DatatypeProperty ; rdfs:label "has unit"@en ; rdfs:comment "Compatibility alias for top:unit."@en ; rdfs:subPropertyOf top:unit .

# -----------------------------------------------------------------------------
# Data properties: semantic metadata and provenance literals
# -----------------------------------------------------------------------------

top:ontologyClass rdf:type owl:DatatypeProperty ; rdfs:label "ontology class"@en ; rdfs:comment "The ontology class QName or URI stored in a TopologicPy dictionary."@en ; rdfs:range xsd:string .
top:ontologyURI rdf:type owl:DatatypeProperty ; rdfs:label "ontology URI"@en ; rdfs:comment "The full URI associated with a TopologicPy semantic class or entity."@en ; rdfs:range xsd:anyURI .
top:uri rdf:type owl:DatatypeProperty ; rdfs:label "URI"@en ; rdfs:comment "An entity URI or identifier stored in a TopologicPy dictionary."@en ; rdfs:range xsd:string .
top:label rdf:type owl:DatatypeProperty ; rdfs:label "label"@en ; rdfs:comment "A human-readable label stored in a TopologicPy dictionary."@en ; rdfs:range xsd:string ; rdfs:subPropertyOf rdfs:label .
top:category rdf:type owl:DatatypeProperty ; rdfs:label "category"@en ; rdfs:comment "A broad TopologicPy category, such as space, element, graph, topology, or interface."@en ; rdfs:range xsd:string .
top:ifcClass rdf:type owl:DatatypeProperty ; rdfs:label "IFC class"@en ; rdfs:comment "The IFC entity type associated with the entity."@en ; rdfs:range xsd:string .
top:ifcGUID rdf:type owl:DatatypeProperty ; rdfs:label "IFC GUID"@en ; rdfs:comment "The IFC GlobalId associated with the entity."@en ; rdfs:range xsd:string .
top:ifcGlobalId rdf:type owl:DatatypeProperty ; rdfs:label "IFC GlobalId"@en ; rdfs:comment "Compatibility alias for top:ifcGUID."@en ; rdfs:subPropertyOf top:ifcGUID .
top:source rdf:type owl:DatatypeProperty ; rdfs:label "source"@en ; rdfs:comment "The source file, database, method, or process associated with the entity."@en ; rdfs:range xsd:string .
top:generatedByMethod rdf:type owl:DatatypeProperty ; rdfs:label "generated by method"@en ; rdfs:comment "A literal method or process name that generated the entity."@en ; rdfs:range xsd:string .
top:createdAt rdf:type owl:DatatypeProperty ; rdfs:label "created at"@en ; rdfs:comment "The creation timestamp."@en ; rdfs:range xsd:dateTime .
top:modifiedAt rdf:type owl:DatatypeProperty ; rdfs:label "modified at"@en ; rdfs:comment "The last modification timestamp."@en ; rdfs:range xsd:dateTime .
top:updatedAt rdf:type owl:DatatypeProperty ; rdfs:label "updated at"@en ; rdfs:comment "Compatibility alias for top:modifiedAt."@en ; rdfs:subPropertyOf top:modifiedAt .

# Dictionary-key compatibility aliases used by TopologicPy Python dictionaries.
top:ontology_class rdf:type owl:DatatypeProperty ; rdfs:label "ontology_class"@en ; rdfs:comment "Compatibility alias for the TopologicPy dictionary key ontology_class."@en ; rdfs:subPropertyOf top:ontologyClass .
top:ontology_uri rdf:type owl:DatatypeProperty ; rdfs:label "ontology_uri"@en ; rdfs:comment "Compatibility alias for the TopologicPy dictionary key ontology_uri."@en ; rdfs:subPropertyOf top:ontologyURI .
top:ifc_class rdf:type owl:DatatypeProperty ; rdfs:label "ifc_class"@en ; rdfs:comment "Compatibility alias for the TopologicPy dictionary key ifc_class."@en ; rdfs:subPropertyOf top:ifcClass .
top:ifc_guid rdf:type owl:DatatypeProperty ; rdfs:label "ifc_guid"@en ; rdfs:comment "Compatibility alias for the TopologicPy dictionary key ifc_guid."@en ; rdfs:subPropertyOf top:ifcGUID .
top:derived_from rdf:type owl:DatatypeProperty ; rdfs:label "derived_from"@en ; rdfs:comment "Compatibility literal property for the TopologicPy dictionary key derived_from."@en ; rdfs:range xsd:string .
top:generated_by rdf:type owl:DatatypeProperty ; rdfs:label "generated_by"@en ; rdfs:comment "Compatibility alias for the TopologicPy dictionary key generated_by."@en ; rdfs:subPropertyOf top:generatedByMethod .

# -----------------------------------------------------------------------------
# Data properties: graph ML and analysis values
# -----------------------------------------------------------------------------

top:graphId rdf:type owl:DatatypeProperty ; rdfs:label "graph id"@en ; rdfs:comment "The graph identifier used in graph datasets."@en ; rdfs:range xsd:string .
top:nodeId rdf:type owl:DatatypeProperty ; rdfs:label "node id"@en ; rdfs:comment "The node identifier used in graph datasets."@en ; rdfs:range xsd:string .
top:edgeId rdf:type owl:DatatypeProperty ; rdfs:label "edge id"@en ; rdfs:comment "The edge identifier used in graph datasets."@en ; rdfs:range xsd:string .
top:srcId rdf:type owl:DatatypeProperty ; rdfs:label "source id"@en ; rdfs:comment "The source node identifier used in graph datasets."@en ; rdfs:range xsd:string .
top:dstId rdf:type owl:DatatypeProperty ; rdfs:label "destination id"@en ; rdfs:comment "The destination node identifier used in graph datasets."@en ; rdfs:range xsd:string .
top:featureValue rdf:type owl:DatatypeProperty ; rdfs:label "feature value"@en ; rdfs:comment "A feature value associated with a graph, node, edge, or attribute."@en .
top:metricValue rdf:type owl:DatatypeProperty ; rdfs:label "metric value"@en ; rdfs:comment "The numeric, categorical, or textual value of an analysis metric."@en .
top:trainMask rdf:type owl:DatatypeProperty ; rdfs:label "train mask"@en ; rdfs:comment "Whether a graph dataset item belongs to the training split."@en ; rdfs:range xsd:boolean .
top:valMask rdf:type owl:DatatypeProperty ; rdfs:label "validation mask"@en ; rdfs:comment "Whether a graph dataset item belongs to the validation split."@en ; rdfs:range xsd:boolean .
top:testMask rdf:type owl:DatatypeProperty ; rdfs:label "test mask"@en ; rdfs:comment "Whether a graph dataset item belongs to the test split."@en ; rdfs:range xsd:boolean .

